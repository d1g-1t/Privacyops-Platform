APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8700

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=privacyops
POSTGRES_USER=pops
POSTGRES_PASSWORD=pops

REDIS_HOST=redis
REDIS_PORT=6700
REDIS_PASSWORD=change-me-redis-secret

OLLAMA_BASE_URL=http://ollama:11700
OLLAMA_CHAT_MODEL=qwen2.5:14b

PASETO_SECRET_KEY=replace-with-32-byte-secret-key!
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14

OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4700
OTEL_SERVICE_NAME=privacyops-api

ENABLE_LOG_MASKING=true
CORS_ALLOW_ORIGINS=http://localhost:3702,http://localhost:8700

DEFAULT_DSR_SLA_DAYS=30
CONSENT_EXPIRY_WARNING_DAYS=30
LOCALIZATION_STRICT_MODE=true
PROCESSOR_REVIEW_REJECTION_THRESHOLD=80
